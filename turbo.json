{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "transit": {
      "dependsOn": [
        "^transit"
      ]
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "transit"
      ],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "transit"
      ],
      "outputs": []
    },
    "openapi:export": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "openapi.json"
      ]
    },
    "openapi:types": {
      "dependsOn": [
        "api-erp#openapi:export"
      ],
      "outputs": [
        "src/lib/api/generated/schema.d.ts"
      ]
    }
  }
}
