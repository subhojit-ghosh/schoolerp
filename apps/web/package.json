    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.10",
    "eslint": "^9.38.0",
    "eslint-config-next": "^16.1.6",
    "inngest-cli": "^1.17.5",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
