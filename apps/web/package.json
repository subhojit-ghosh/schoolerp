    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "inngest": "^3.52.6",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "next-safe-action": "^8.1.8",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "openapi-fetch": "^0.17.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
