{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n metadata,api -c yellow,cyan \"bun run openapi:metadata:watch\" \"nest start --watch --builder webpack\"",
    "build": "bun run openapi:metadata && nest build --builder webpack",
    "start": "bun dist/main.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "openapi:metadata": "ts-node --project tsconfig.json src/generate-metadata.ts",
    "openapi:metadata:watch": "ts-node --project tsconfig.json src/generate-metadata.ts --watch",
    "openapi:export": "bun run openapi:metadata && bun run src/export-openapi.ts"
  },
  "dependencies": {
    "@academic-platform/backend-core": "workspace:*",
    "@academic-platform/database": "workspace:*",
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.6",
    "@scalar/nestjs-api-reference": "^1.1.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.8",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/node": "^25.4.0",
    "concurrently": "^9.2.1",
    "swc-loader": "^0.2.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
