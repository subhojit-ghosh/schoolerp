{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@academic-platform/backend-core": [
        "../../packages/backend-core/src/index.ts"
      ],
      "@academic-platform/database": [
        "../../packages/database/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
