  "servers": [],
  "components": {
    "schemas": {
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "SignUpBodyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "mobile": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "mobile",
          "email",
          "password"
        ]
      },
      "AuthUserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "mobile": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "mobile",
          "email"
        ]
      },
      "AuthSessionDto": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/AuthUserDto"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "user",
          "expiresAt"
        ]
      },
      "SignInBodyDto": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "identifier",
          "password"
        ]
      },
      "AcademicYearDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string"
          },
          "isCurrent": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "archived"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "startDate",
          "endDate",
          "isCurrent",
          "status",
          "createdAt"
        ]
      },
      "CreateAcademicYearBodyDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "startDate": {
            "type": "string"
          },
          "endDate": {
            "type": "string"
          },
          "makeCurrent": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "startDate",
          "endDate",
          "makeCurrent"
        ]
      },
      "InstitutionDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "institutionType": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "string",
            "nullable": true,
            "enum": [
              "active",
              "suspended"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "slug",
          "institutionType",
          "status",
          "createdAt"
        ]
      },
      "ListInstitutionsResultDto": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InstitutionDto"
            }
          },
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "pageSize": {
            "type": "number"
          },
          "pageCount": {
            "type": "number"
          }
        },
        "required": [
          "rows",
          "total",
          "page",
          "pageSize",
          "pageCount"
        ]
      },
      "InstitutionCountsDto": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          },
          "active": {
            "type": "number"
          },
          "suspended": {
            "type": "number"
          }
        },
        "required": [
          "total",
          "active",
          "suspended"
        ]
      },
      "TenantBrandingDto": {
        "type": "object",
        "properties": {
          "institutionName": {
            "type": "string"
          },
          "shortName": {
            "type": "string"
          },
          "tenantSlug": {
            "type": "string"
          },
          "logoUrl": {
            "type": "string",
            "nullable": true
          },
          "faviconUrl": {
            "type": "string",
            "nullable": true
          },
          "primaryColor": {
            "type": "string"
          },
          "accentColor": {
            "type": "string"
          },
          "sidebarColor": {
            "type": "string"
          }
        },
        "required": [
          "institutionName",
          "shortName",
          "tenantSlug",
          "logoUrl",
          "faviconUrl",
          "primaryColor",
          "accentColor",
          "sidebarColor"
        ]
      }
    }
  }
}