{
  "name": "api-erp",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun run openapi:metadata && nest build",
    "format": "prettier --config ../../.prettierrc.json --ignore-path ../../.prettierignore --write .",
    "start": "nest start",
    "start:dev": "bun run openapi:metadata && nest start --watch",
    "start:debug": "bun run openapi:metadata && nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "dev": "bun run start:dev",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "bun run format && eslint \"{src,test}/**/*.ts\" --fix",
    "test": "bun test ./src",
    "typecheck": "tsc --noEmit",
    "openapi:metadata": "ts-node --project tsconfig.json src/generate-metadata.ts",
    "openapi:metadata:watch": "ts-node --project tsconfig.json src/generate-metadata.ts --watch",
    "openapi:export": "bun run openapi:metadata && bun run src/export-openapi.ts"
  },
  "dependencies": {
    "@repo/backend-core": "workspace:*",
    "@repo/contracts": "workspace:*",
    "@repo/database": "workspace:*",
    "@nestjs/common": "^11.1.8",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.8",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.8",
    "@nestjs/swagger": "^11.2.6",
    "@scalar/nestjs-api-reference": "^1.1.2",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.1",
    "express": "^5.1.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/node": "^25.5.0",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "bun-types": "^1.3.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
