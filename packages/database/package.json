{
  "name": "@repo/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth-schema": {
      "types": "./src/schema/auth.ts",
      "default": "./dist/schema/auth.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "db:generate": "bun --env-file=.env.local drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun --env-file=.env.local drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "bun --env-file=.env.local drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3"
  }
}
