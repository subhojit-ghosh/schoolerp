{
  "name": "@academic-platform/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./auth-schema": "./src/schema/auth.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun --env-file=.env.local drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "bun --env-file=.env.local drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "bun --env-file=.env.local drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3"
  }
}
