{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "format": "prettier --config ../../.prettierrc.json --ignore-path ../../.prettierignore --write .",
