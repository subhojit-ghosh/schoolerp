{
	email admin@example.com
}

erp.example.com {
	encode zstd gzip

	handle_path /api/* {
		reverse_proxy 127.0.0.1:5002
	}

	handle /openapi.json {
		reverse_proxy 127.0.0.1:5002
	}

	handle /reference* {
		reverse_proxy 127.0.0.1:5002
	}

	handle {
		reverse_proxy 127.0.0.1:5001
	}
}

*.erp.example.com {
	# Wildcard tenant hosts require a wildcard certificate.
	# Configure a DNS challenge for your DNS provider before using this block.
	# Example:
	# tls {
	#   dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	# }

	handle_path /api/* {
		reverse_proxy 127.0.0.1:5002
	}

	handle /openapi.json {
		reverse_proxy 127.0.0.1:5002
	}

	handle /reference* {
		reverse_proxy 127.0.0.1:5002
	}

	handle {
		reverse_proxy 127.0.0.1:5000
	}
}
