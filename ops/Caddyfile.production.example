{
	email admin@example.com

	on_demand_tls {
		ask http://127.0.0.1:5002/internal/tls/allow
	}
}

https:// {
	tls {
		on_demand
	}

	encode zstd gzip

	@api path /api/*
	@docs path /openapi.json /reference*
	@root host erp.example.com

	handle @api {
		uri strip_prefix /api
		reverse_proxy 127.0.0.1:5002
	}

	handle @docs {
		reverse_proxy 127.0.0.1:5002
	}

	handle @root {
		reverse_proxy 127.0.0.1:5001
	}

	handle {
		reverse_proxy 127.0.0.1:5000
	}
}
