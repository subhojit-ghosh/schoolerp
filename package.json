{
  "name": "academic-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "api:openapi": "bun run --cwd apps/api openapi:export",
    "api:types": "bun run api:openapi && bun run --cwd apps/web api:types:generate",
    "db:generate": "bun run --cwd packages/database db:generate",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:studio": "bun run --cwd packages/database db:studio",
    "seed": "bun run --cwd apps/web seed",
    "inngest:dev": "bun run --cwd apps/web inngest:dev"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  }
}
