{
  "name": "academic-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:erp": "turbo run dev --filter=erp",
    "dev:api-erp": "turbo run dev --filter=api-erp",
    "build": "turbo run build",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "api-erp:openapi": "turbo run openapi:export --filter=api-erp",
    "erp:openapi-types": "turbo run openapi:types --filter=erp",
    "db:generate": "bun run --cwd packages/database db:generate",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:studio": "bun run --cwd packages/database db:studio"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.8.17"
  },
  "dependencies": {
    "@scalar/nestjs-api-reference": "^1.1.3"
  }
}
