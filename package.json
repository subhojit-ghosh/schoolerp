{
  "name": "academic-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:erp": "turbo dev --filter=erp",
    "dev:api-erp": "turbo dev --filter=api-erp",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "api-erp:openapi": "bun run --cwd apps/api-erp openapi:export",
    "erp:openapi-types": "bun run --cwd apps/erp openapi:types",
    "db:generate": "bun run --cwd packages/database db:generate",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:studio": "bun run --cwd packages/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.8.16"
  }
}
